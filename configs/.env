PROJECT_NAME=olist-ecommerce-intelligence-platform
ENVIRONMENT=development
LOG_LEVEL=INFO

DATA_PATH=data/raw

BRONZE_PATH=data/bronze
SILVER_PATH=data/silver
GOLD_PATH=data/gold

KAFKA_BOOTSTRAP_SERVER=localhost:9092
KAFKA_TOPIC_ORDERS=orders

SPARK_APP_NAME=olist-data-platform

USE_AZURE_KEY_VAULT=false
AZURE_KEY_VAULT_URL=

# Kafka
KAFKA_NODE_ID=1
KAFKA_KRAFT_CLUSTER_ID=43orMnJMQ26kRfQ2qMYc5g

KAFKA_HOST_PORT=9092
KAFKA_UI_PORT=8080

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_NUM_PARTITIONS=3
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0

KAFKA_UI_CLUSTER_NAME=olist-kraft

# PostgreSQL
POSTGRES_DB=olist
POSTGRES_USER=olist
POSTGRES_PASSWORD=olist
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
